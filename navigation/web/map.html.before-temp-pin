<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width,
                 initial-scale=1.0,
                 maximum-scale=1.0,
                 user-scalable=no"
    >

    <title>Off-Road Map</title>

    <link rel="stylesheet" href="leaflet.css">

    <style>
        html,
        body,
        #map {
            width: 100%;
            height: 100%;
            margin: 0;
            padding: 0;
            overflow: hidden;
            background: #101820;
        }

        .leaflet-control-zoom a {
            width: 56px !important;
            height: 56px !important;
            line-height: 56px !important;
            font-size: 30px !important;
            color: white !important;
            background: #141b23 !important;
            border-color: #2a3947 !important;
        }

        .leaflet-control-attribution {
            color: #c6d0da;
            background: rgba(10, 15, 20, 0.78) !important;
        }

        .vehicle-marker {
            width: 30px;
            height: 30px;
            background: #2da8ff;
            border: 4px solid white;
            border-radius: 50%;
            box-shadow: 0 0 12px black;
        }

        .waypoint-marker {
            width: 24px;
            height: 24px;
            background: #ffb347;
            border: 3px solid white;
            border-radius: 50%;
            box-shadow: 0 0 8px black;
            cursor: pointer;
        }

        .waypoint-marker-selected {
            width: 30px;
            height: 30px;
            background: #ffb347;
            border: 4px solid #2da8ff;
            border-radius: 50%;
            box-shadow:
                0 0 8px black,
                0 0 14px #2da8ff;
            cursor: pointer;
        }
    </style>
</head>

<body>
    <div id="map"></div>

    <script src="leaflet.js"></script>
    <script src="qrc:///qtwebchannel/qwebchannel.js"></script>

    <script>
        const startingPosition = [
            33.432472564,
            -111.608407937
        ];

        let mapBridge = null;
        let selectedWaypointId = "";

        const waypointMarkers = [];

        const map = L.map("map", {
            zoomControl: false,
            attributionControl: true,
            preferCanvas: true,
            doubleClickZoom: true,
            touchZoom: true,
            dragging: true
        });

        map.setView(startingPosition, 11);

        const tiles = L.tileLayer(
            "https://tile.openstreetmap.org/{z}/{x}/{y}.png",
            {
                minZoom: 2,
                maxZoom: 19,
                attribution:
                    "&copy; OpenStreetMap contributors"
            }
        );

        tiles.addTo(map);

        const vehicleIcon = L.divIcon({
            className: "",
            html:
                '<div class="vehicle-marker"></div>',
            iconSize: [38, 38],
            iconAnchor: [19, 19]
        });

        function createWaypointIcon(selected) {
            const markerClass = selected
                ? "waypoint-marker-selected"
                : "waypoint-marker";

            const size = selected ? 38 : 30;
            const anchor = size / 2;

            return L.divIcon({
                className: "",
                html:
                    '<div class="' +
                    markerClass +
                    '"></div>',
                iconSize: [size, size],
                iconAnchor: [anchor, anchor]
            });
        }

        const vehicleMarker = L.marker(
            startingPosition,
            {
                icon: vehicleIcon,
                zIndexOffset: 1000
            }
        ).addTo(map);

        const simulatedTrack = [];

        const trackLine = L.polyline(
            simulatedTrack,
            {
                color: "#2da8ff",
                weight: 6,
                opacity: 0.85
            }
        ).addTo(map);

        let simulationRunning = false;

        function initializeWebChannel() {
            if (
                typeof qt === "undefined" ||
                !qt.webChannelTransport
            ) {
                console.error(
                    "Qt WebChannel transport unavailable."
                );
                return;
            }

            new QWebChannel(
                qt.webChannelTransport,
                function(channel) {
                    mapBridge =
                        channel.objects.mapBridge;

                    if (!mapBridge) {
                        console.error(
                            "mapBridge was not registered."
                        );
                        return;
                    }

                    console.log(
                        "Qt WebChannel connected."
                    );

                    mapBridge.pageLoaded();
                }
            );
        }

        initializeWebChannel();

        map.on(
            "click",
            function(event) {
                const latitude =
                    event.latlng.lat;

                const longitude =
                    event.latlng.lng;

                console.log(
                    "Leaflet map clicked:",
                    latitude,
                    longitude
                );

                if (!mapBridge) {
                    console.error(
                        "Map click ignored because mapBridge is not connected."
                    );
                    return;
                }

                if (!mapBridge.mapPressedSlot) {
                    console.error(
                        "mapPressedSlot is not available on mapBridge."
                    );
                    return;
                }

                console.log(
                    "Sending map coordinates to Qt."
                );

                mapBridge.mapPressedSlot(
                    latitude,
                    longitude
                );
            }
        );

        function zoomIn() {
            map.zoomIn();
        }

        function zoomOut() {
            map.zoomOut();
        }

        function recenterVehicle() {
            map.setView(
                vehicleMarker.getLatLng(),
                Math.max(map.getZoom(), 15)
            );
        }

        function toggleSimulation() {
            simulationRunning =
                !simulationRunning;

            return simulationRunning;
        }

        function getVehiclePositionJson() {
            const position =
                vehicleMarker.getLatLng();

            return JSON.stringify({
                latitude: position.lat,
                longitude: position.lng
            });
        }

        function clearWaypoints() {
            waypointMarkers.forEach(
                function(marker) {
                    map.removeLayer(marker);
                }
            );

            waypointMarkers.length = 0;
        }

        function updateWaypointSelection() {
            waypointMarkers.forEach(
                function(marker) {
                    const isSelected =
                        marker.waypointId ===
                        selectedWaypointId;

                    marker.setIcon(
                        createWaypointIcon(
                            isSelected
                        )
                    );

                    marker.setZIndexOffset(
                        isSelected ? 800 : 100
                    );
                }
            );
        }

        function selectWaypointMarker(
            waypointId
        ) {
            selectedWaypointId =
                String(waypointId || "");

            updateWaypointSelection();
        }

        function addWaypointMarker(
            id,
            latitude,
            longitude,
            name,
            category
        ) {
            const marker = L.marker(
                [latitude, longitude],
                {
                    icon:
                        createWaypointIcon(
                            id ===
                            selectedWaypointId
                        ),
                    zIndexOffset: 100
                }
            ).addTo(map);

            marker.waypointId =
                String(id);

            marker.waypointName =
                name;

            marker.waypointCategory =
                category;

            marker.on(
                "click",
                function(event) {
                    L.DomEvent.stopPropagation(
                        event
                    );

                    selectWaypointMarker(
                        marker.waypointId
                    );

                    console.log(
                        "Waypoint clicked:",
                        marker.waypointId
                    );

                    if (
                        mapBridge &&
                        mapBridge.selectWaypoint
                    ) {
                        mapBridge.selectWaypoint(
                            marker.waypointId
                        );
                    } else {
                        console.error(
                            "mapBridge is not connected."
                        );
                    }
                }
            );

            waypointMarkers.push(marker);
        }

        function loadWaypoints(jsonText) {
            clearWaypoints();

            let waypoints;

            try {
                waypoints =
                    JSON.parse(jsonText);
            } catch (error) {
                console.error(
                    "Could not parse waypoints:",
                    error
                );
                return;
            }

            waypoints.forEach(
                function(waypoint) {
                    addWaypointMarker(
                        waypoint.id,
                        Number(
                            waypoint.latitude
                        ),
                        Number(
                            waypoint.longitude
                        ),
                        waypoint.name ||
                            "Waypoint",
                        waypoint.category ||
                            "WAYPOINT"
                    );
                }
            );

            updateWaypointSelection();
        }

        function centerOnWaypoint(
            waypointId
        ) {
            const cleanedId =
                String(waypointId);

            const marker =
                waypointMarkers.find(
                    function(item) {
                        return (
                            item.waypointId ===
                            cleanedId
                        );
                    }
                );

            if (!marker) {
                return false;
            }

            selectWaypointMarker(
                cleanedId
            );

            map.setView(
                marker.getLatLng(),
                Math.max(
                    map.getZoom(),
                    16
                )
            );

            return true;
        }

        function clearWaypointSelection() {
            selectedWaypointId = "";
            updateWaypointSelection();
        }
    </script>
</body>
</html>
